<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/overlay_background"
    android:clickable="true"
    android:focusable="true"
    android:padding="32dp">

    <TextView
        android:id="@+id/overlayTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/overlay_text"
        android:textSize="14sp"
        android:alpha="0.7"
        android:layout_marginBottom="12dp"
        tools:text="14:32:10" />

    <TextView
        android:id="@+id/overlayTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/overlay_title"
        android:textColor="@color/overlay_text"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/overlayBlockedSite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/overlay_text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"
        tools:text="youtube.com" />

    <TextView
        android:id="@+id/overlayBlockedKeyword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/overlay_text"
        android:alpha="0.8"
        android:textSize="13sp"
        android:layout_marginBottom="28dp"
        tools:text="Blocked keyword: youtube" />

    <TextView
        android:id="@+id/overlayQuote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/overlay_text"
        android:textSize="18sp"
        android:layout_marginBottom="40dp"
        tools:text="Discipline is choosing between what you want now and what you want most." />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayGoBackButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:layout_marginBottom="12dp"
        android:text="@string/overlay_go_back" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/overlayCloseAppButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/overlay_text"
        android:text="@string/overlay_close_app" />

</LinearLayout>
